rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Accountant uploads: payment proofs and rejection images
    // Allow any authenticated user (including anonymous) to read/write
    match /paymentProofs/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /rejectionImages/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // User uploaded files (KYC, profile photos, chat media, etc.)
    // Only the owning user can write; authenticated users can read
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Chat media — any authenticated user can read/write
    match /chatMedia/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // KYC documents — owner write, authenticated read
    match /kyc/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Fallback: authenticated users can read/write everything else
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
